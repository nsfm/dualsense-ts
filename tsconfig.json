{
  "include": ["src/**/*"],
  "compilerOptions": {
    "strict": true,
    "alwaysStrict": true,
    "module": "Node16",
    "target": "ES2020",
    "moduleResolution": "Node16",
    "lib": ["ES2021", "DOM"],
    "types": ["node", "jest", "w3c-web-hid"],
    "isolatedModules": true,
    "incremental": true,
    "declaration": true,
    "declarationMap": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "rootDir": "src",
    "outDir": "dist",
    "sourceMap": true
  },
  "lib": ["esnext"]
}
